# Telegram configuration
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Database configuration
# Leave empty to use local SQLite (expenses.db)
DATABASE_URL=postgres://user:password@host:port/dbname?sslmode=require

# Cloud hosting configuration (required for webhook mode on Render/etc)
# If set, the bot will run in Webhook mode. If empty, it will run in Polling mode.
RENDER_EXTERNAL_URL=https://your-app-name.onrender.com
PORT=8000

# Default configuration overrides (optional, normally set in config.json)
# CURRENCY=₹
# MONTHLY_BUDGET=50000
